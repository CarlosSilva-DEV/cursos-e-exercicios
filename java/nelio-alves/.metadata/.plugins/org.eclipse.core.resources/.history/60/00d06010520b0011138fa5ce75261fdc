package entities;

public class PessoaJuridica extends Pessoa {
	private Integer numOfEployees;
	
	// Construtor
	public PessoaJuridica() {
	}

	public PessoaJuridica(String name, Double yearIncome, Integer numOfEployees) {
		super(name, yearIncome);
		this.numOfEployees = numOfEployees;
	}
	
	// getters e setters
	public Integer getNumOfEployees() {
		return numOfEployees;
	}
	public void setNumOfEployees(Integer numOfEployees) {
		this.numOfEployees = numOfEployees;
	}
}
