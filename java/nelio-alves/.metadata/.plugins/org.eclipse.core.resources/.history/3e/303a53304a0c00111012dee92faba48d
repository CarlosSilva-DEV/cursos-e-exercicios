package application;

import java.util.Locale;
import java.util.Scanner;

import jdk.internal.org.jline.terminal.TerminalBuilder.SystemOutput;
import model.entities.Contract;

public class Main {

	public static void main(String[] args) {
		Locale.setDefault(Locale.US);
		Scanner input = new Scanner(System.in);
		Contract c = new Contract();
		
		System.out.println("Insert the contract data:");
		System.out.print("Number: ");
		c.setNumber(input.nextInt());
		
		System.out.print("Date (dd/MM/yyyy): ");
		String date = input.nextLine();
		c.setDate(date);
		
		System.out.print("Contract total value: $ ");
		c.setTotalValue(input.nextDouble());
		
		System.out.print("Insert the number of installments: ");
		int n = input.nextInt();
		
		System.out.println("\n\nINSTALLMENTS:");
		for (int i = 1; i <= n; i++) {
			System.out.println(c.getInstallments());
		}
		
	}
}