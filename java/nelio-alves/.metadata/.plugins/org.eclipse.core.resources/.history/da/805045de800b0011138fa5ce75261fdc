package application;

import java.time.LocalDate;
import java.time.format.DateTimeFormatter;
import java.util.Locale;
import java.util.Scanner;

import entities.Reservation;

public class Main {

	public static void main(String[] args) {
		Locale.setDefault(Locale.US);
		Scanner input = new Scanner(System.in);
		Reservation r = new Reservation();
		
		// registro da reserva
		System.out.print("Room number: ");
		r.setRoomNumber(input.nextInt());
		
		System.out.print("Check-in date (dd/MM/yyyy): ");
		String checkinString = input.nextLine();
		System.out.print("Check-out date (dd/MM/yyyy): ");
		String checkoutString = input.nextLine();
		
		LocalDate checkin = LocalDate.parse(checkoutString, r.dtf);
		LocalDate checkout = LocalDate.parse(checkoutString, r.dtf);
		
		if (checkout.isBefore(checkin)) {
			System.out.println("Reservation Error: Check-out date must be after check-in date");
		} else {
			
		}
		
		r.updateDates(checkin, checkout);
		
		
		
		System.out.println(r);
		
		// atualização da reserva
		System.out.println("\n\nEnter data to update the reservation:");
		
		System.out.print("Check-in date (dd/MM/yyyy): ");
		String updatedCheckin = input.nextLine();
		System.out.print("Check-out date (dd/MM/yyyy): ");
		String updatedCheckout = input.nextLine();
		
		r.updateDates(updatedCheckin, updatedCheckout);
		System.out.println(r);
		
		input.close();
	}
}