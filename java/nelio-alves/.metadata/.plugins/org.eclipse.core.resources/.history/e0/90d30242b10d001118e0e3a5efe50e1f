package application;

import java.util.Set;
import java.util.TreeSet;

public class Main {

	public static void main(String[] args) {
		Set<String> set = new TreeSet<>();
		
		set.add("TV");
		set.add("Notebook");
		set.add("Tablet");
		
		for (String s : set) {
			System.out.println(s);
		}
		
		System.out.println("contains 'Notebook'?: " + set.contains("Notebook"));
	}
}