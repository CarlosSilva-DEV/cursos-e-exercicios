package problema2.application;

import java.util.ArrayList;
import java.util.List;

import problema2.entities.Product;
import problema2.util.PriceUpdate;

public class Main {

	public static void main(String[] args) {
		List<Product> list = new ArrayList<>();
		
		list.add(new Product("TV", 900.00));
		list.add(new Product("Mouse", 50.00));
		list.add(new Product("Tablet", 350.50));
		list.add(new Product("HD Case", 80.90));
		
		// IMPLEMENTAÇÃO DA INTERFACE CONSUMER
		PriceUpdate consumer = new PriceUpdate();
		list.forEach(consumer);
		
		// usando reference method pro sysout
		list.forEach(System.out::println);
	}
}