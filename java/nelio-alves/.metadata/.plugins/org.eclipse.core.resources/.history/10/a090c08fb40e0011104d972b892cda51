package application;

import java.util.Arrays;
import java.util.List;
import java.util.stream.Collectors;

public class Main {

	public static void main(String[] args) {
		List<Integer> list = Arrays.asList(3, 4, 5, 10, 7);
		
		// criando uma stream, reduzindo os elementos com base no predicado (soma o elemento atual com o próximo)
		Integer sum = list.stream().reduce(0, (x, y) -> x + y);
		System.out.println("Sum: " + sum);
		
		// criando nova lista que recebe a lista anterior e cria um stream
		List<Integer> newList = list.stream()
				.filter(x -> x % 2 == 0) // filtrando por números pares
				.map(x -> x * 10) // aplicando multiplicação por 10 aos números filtrados
				.collect(Collectors.toList()); // convertendo de volta para lista
		
		System.out.println(Arrays.toString(newList.toArray()));
	}
}
