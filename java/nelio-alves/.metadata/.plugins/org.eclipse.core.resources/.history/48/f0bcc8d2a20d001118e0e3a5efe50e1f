package entities;

public class Circle {
	private Double radius;
	
	// Construtor
	public Circle() {
	}

	public Circle(Double radius) {
		this.radius = radius;
	}
	
	// getters e setters
	public Double getRadius() {
		return radius;
	}
	public void setRadius(Double radius) {
		this.radius = radius;
	}
	
	
}
