package application;

import java.time.LocalDate;
import java.util.Locale;
import java.util.Scanner;

import entities.Reservation;

public class Main {

	public static void main(String[] args) {
		Locale.setDefault(Locale.US);
		Scanner input = new Scanner(System.in);
		Reservation r = new Reservation();

		// registro da reserva
		System.out.print("Room number: ");
		r.setRoomNumber(input.nextInt());

		System.out.print("Check-in date (dd/MM/yyyy): ");
		String checkinString = input.nextLine();
		System.out.print("Check-out date (dd/MM/yyyy): ");
		String checkoutString = input.nextLine();

		LocalDate checkin = LocalDate.parse(checkinString, r.dtf);
		LocalDate checkout = LocalDate.parse(checkoutString, r.dtf);

		if (checkout.isBefore(checkin)) {
			System.out.println("Reservation Error: Check-out date must be after check-in date");
		} else {
			r.updateDates(checkin, checkout);
			System.out.println(r);
		}

		// atualização da reserva
		System.out.println("Do you want to update the reservation info (y/n)? ");
		char updateResponse = input.next().charAt(0);

		switch (updateResponse) {
			case 'y':
				System.out.println("\n\nEnter data to update the reservation:");
	
				System.out.print("Check-in date (dd/MM/yyyy): ");
				String updatedCheckinString = input.nextLine();
				System.out.print("Check-out date (dd/MM/yyyy): ");
				String updatedCheckoutString = input.nextLine();
	
				LocalDate updatedCheckin = LocalDate.parse(updatedCheckinString, r.dtf);
				LocalDate updatedCheckout = LocalDate.parse(updatedCheckoutString, r.dtf);
	
				if (updatedCheckout.isBefore(updatedCheckin)) {
					System.out.println("Update Error: Check-out date must be after check-in date");
				} else {
					r.updateDates(updatedCheckin, updatedCheckout);
					System.out.println(r);
				}
				
				break;
			case 'n':
				break;
			default:
				System.out.println("Invalid input, please try again");
		}

		input.close();
		System.out.print("***END OF THE APPLICATION***");
	}
}