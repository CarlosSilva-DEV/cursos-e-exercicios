package application;

import java.io.BufferedReader;
import java.io.BufferedWriter;
import java.io.File;
import java.io.FileReader;
import java.io.FileWriter;
import java.io.IOException;
import java.util.ArrayList;
import java.util.List;
import java.util.Locale;
import java.util.Scanner;

import entities.Product;

public class Main {

	public static void main(String[] args) {
		Locale.setDefault(Locale.US);
		Scanner input = new Scanner(System.in);
		List<Product> products = new ArrayList<>();
		
		System.out.print("Enter the file path: ");
		String path = input.nextLine();
		
		// instanciando objeto File a partir do caminho original
		File sourceFile = new File(path);
		String sourceFolder = sourceFile.getParent(); // armazenando apenas caminho
		
		boolean success = new File(sourceFolder + "/out").mkdir();
		
		// armazenando caminho do novo arquivo
		String targetFile = sourceFolder + "/out/summary.csv";
		
		// try para ler o arquivo no caminho original
		try (BufferedReader br = new BufferedReader(new FileReader(path))) {
			String line = br.readLine();
			
			// enquanto houver linhas, splita dados por "," e instancia Product
			while (line != null) {
				String[] fields = line.split(",");

				String name = fields[0];
				Double price = Double.parseDouble(fields[1]);
				Integer quantity = Integer.parseInt(fields[2]);

				products.add(new Product(name, price, quantity));

				line = br.readLine();
			}
			// try para escrever informações no novo arquivo
			try (BufferedWriter bw = new BufferedWriter(new FileWriter(targetFile))) {
				for (Product p : products) {
					bw.write(p.getName() + "," + String.format("%.2f", p.total()));
					bw.newLine();
				}
				System.out.println("Directory created: " + targetFile);
			} catch (IOException e) {
				System.out.println("Error writing file: " + e.getMessage());
			}

		} catch (IOException e) {
			System.out.println("Error reading file: " + e.getMessage());
		} finally {
			input.close();
		}

	}
}