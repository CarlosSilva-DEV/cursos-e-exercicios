package problema2.application;

import java.util.Arrays;
import java.util.Set;
import java.util.TreeSet;

public class Main {

	public static void main(String[] args) {
		Set<Integer> a = new TreeSet<>(Arrays.asList(0, 2, 4, 5, 6, 8, 10));
		Set<Integer> b = new TreeSet<>(Arrays.asList(1, 2, 3, 5, 7, 8, 9, 10));
		
		// União: une elementos em um novo Set, desconsiderando repetições
		Set<Integer> union = new TreeSet<>(a);
		union.addAll(b);
		System.out.println("United Set: " + union);
		
		// Interseção: retém em um novo Set todos os elementos em comum entre ambos
		Set<Integer> intersection = new TreeSet<>(a);
		intersection.retainAll(b);
		System.out.println("Post-Intersection Set: " + intersection);
		
		// Diferença:
		Set<Integer> difference = new TreeSet<>(a);
		difference.removeAll(b);
		System.out.println("Post-Difference Set: " + difference);
	}
}